# Optional: OpenAI API key for local development.
# Copy this file to .env and set your key. The app will use it when the
# selected AI provider is OpenAI and no key is set in Dev Space.
#
# IMPORTANT: The variable name must be exactly:
#   VITE_OPENAI_API_KEY
# (V-I-T-E, no hyphen). A typo like VIT-E_OPENAI_API_KEY will not work.
#
VITE_OPENAI_API_KEY=sk-your-openai-api-key-here
